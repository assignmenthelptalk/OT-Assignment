---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const schemaItems = crumbs.map((crumb, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: crumb.label,
  ...(crumb.href ? { item: `https://otassignmenthelp.co.uk${crumb.href}` } : {}),
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<nav aria-label="Breadcrumb" class="mb-2">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-[var(--color-text-secondary)]">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true" class="text-[var(--color-text-muted)]">›</span>}
        {crumb.href ? (
          <a href={crumb.href} class="text-primary-600 hover:underline hover:text-primary-800">
            {crumb.label}
          </a>
        ) : (
          <span aria-current="page" class="text-[var(--color-text-primary)] font-medium">
            {crumb.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
