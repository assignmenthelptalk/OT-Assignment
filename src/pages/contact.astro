---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact — Get a Free OT Assignment Quote"
  metaTitle="Get a Free OT Assignment Quote — OT Assignment Help"
  metaDescription="Submit your OT assignment brief and get a free quote within 24 hours. Expert OT-qualified writers. BSc, MSc, and OTD levels supported."
  canonicalUrl="/contact"
  ogImage="/images/headers/contact.webp"
>
  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <h1 class="text-4xl font-bold text-primary-800 mb-4">Get a Free Quote</h1>
    <div class="mb-8 rounded-2xl overflow-hidden shadow-lg border border-[var(--color-border)]">
      <img
        src="/images/headers/contact.webp"
        alt="Get a Free OT Assignment Quote"
        width="1920"
        height="960"
        class="w-full h-auto object-cover aspect-[2/1] block"
        loading="eager"
        decoding="async"
        itemprop="image"
      />
    </div>
    <p class="text-lg text-[var(--color-text-secondary)] mb-2 leading-relaxed">
      Tell us your assignment type, qualification level, word count, and deadline. We'll match
      you with an OT-qualified writer and respond within 24 hours.
    </p>
    <p class="text-sm text-[var(--color-text-secondary)] mb-8">
      All enquiries are confidential. No obligation.
    </p>

    <ContactForm
      headingText="Submit Your Assignment Brief"
      subText="Confidential. No obligation. Response within 24 hours."
      formId="contact-form"
    />

    <!-- Process steps -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-primary-800 mb-8 text-center">How It Works</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">

        <div class="bg-[var(--color-bg-surface)] rounded-xl p-6">
          <div class="text-3xl font-bold text-secondary-600 mb-3">1</div>
          <h3 class="font-semibold text-primary-800 mb-2">Submit your brief</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
            Fill in the form above with your assignment type, word count, level, and deadline.
          </p>
        </div>

        <div class="bg-[var(--color-bg-surface)] rounded-xl p-6">
          <div class="text-3xl font-bold text-secondary-600 mb-3">2</div>
          <h3 class="font-semibold text-primary-800 mb-2">Get matched</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
            We match you with an OT-qualified writer who specialises in your assignment type and level.
          </p>
        </div>

        <div class="bg-[var(--color-bg-surface)] rounded-xl p-6">
          <div class="text-3xl font-bold text-secondary-600 mb-3">3</div>
          <h3 class="font-semibold text-primary-800 mb-2">Receive your work</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
            Your assignment is delivered by the agreed deadline. Revisions included.
          </p>
        </div>

      </div>
    </section>

  </main>
</BaseLayout>
