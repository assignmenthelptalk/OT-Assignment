---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactForm from '../components/ContactForm.astro';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  metaTitle?: string;
  metaDescription?: string;
  canonicalUrl: string;
  ogType?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs: Crumb[];
  schemaType?: 'Service' | 'Article' | 'FAQPage';
  headerImage?: string;
}

const {
  breadcrumbs,
  schemaType = 'Service',
  title,
  metaTitle,
  metaDescription,
  canonicalUrl,
  headerImage,
  ...rest
} = Astro.props;

const SITE_URL = 'https://www.occupationtherapyassignment.help';

const schemaJson = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: title,
  url: `${SITE_URL}${canonicalUrl}`,
  ...(metaDescription ? { description: metaDescription } : {}),
  ...(headerImage ? { image: `${SITE_URL}${headerImage}` } : {}),
};
---

<BaseLayout
  title={title}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  canonicalUrl={canonicalUrl}
  ogImage={headerImage || rest.ogImage}
  {...rest}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
  </Fragment>

  <main>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <Breadcrumb crumbs={breadcrumbs} />
      <div class="mt-4 lg:grid lg:grid-cols-[1fr_300px] lg:gap-12">
        <article class="prose-article min-w-0">
          <h1 class="text-3xl font-bold text-primary-800 mb-4">{title}</h1>
          {headerImage && (
            <div class="mb-8 rounded-2xl overflow-hidden shadow-lg border border-[var(--color-border)]">
              <img
                src={headerImage}
                alt={title}
                width="1920"
                height="960"
                class="w-full h-auto object-cover aspect-[2/1] block"
                loading="eager"
                decoding="async"
                itemprop="image"
              />
            </div>
          )}
          <slot />
        </article>
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <ContactForm
              headingText="Get a Free Quote"
              subText="OT-qualified writers. Response within 24 hours."
              formId="sidebar-quote"
              sidebar={true}
            />
          </div>
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
